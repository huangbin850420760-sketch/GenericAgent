      new THREE.BoxGeometry(0.1, 0.02, 0.02),
      mat(cfg.darkColor)
    );
    brow.position.set(side * 0.14, 0.76, 0.32);
    brow.rotation.z = side * -0.15;
    petGroup.add(brow);
  });
}

